<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_category"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_toggle_container">

    <TextView
        android:id="@+id/tv_category_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🍔"
        android:textSize="20sp"
        android:layout_marginEnd="16dp"/>

    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:text="Food"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/iv_check"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_input_add"
        android:visibility="gone"/>
        <!-- For checkmark we can use a custom check icon or tint a system one. I will programmatically set a standard check or tint it. -->

</LinearLayout>
